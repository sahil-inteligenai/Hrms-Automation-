# InteligenAI HRMS Auto-Checkout — copy this file to `.env` and fill in values.

# HRMS site
HRMS_URL=https://hrms.inteligenai.com/

# --- Telegram bot ---
# 1. Open Telegram, talk to @BotFather, send /newbot, follow prompts to get a token.
# 2. Send any message to your new bot from your account.
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates and copy the
#    "chat":{"id":...} value into TELEGRAM_CHAT_ID below.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Gmail (notification only — no IMAP polling) ---
# Generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your Google account).
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
EMAIL_TO=

# --- Behaviour (defaults are fine) ---
AUTH_STATE_PATH=./auth_state.json
SCREENSHOT_DIR=./screenshots
REPLY_TIMEOUT_SECONDS=600
RUN_TIME=22:00
HEADLESS=true

# --- Automated re-auth (optional) ---
# If MS_EMAIL and MS_PASSWORD are set, the daemon will silently re-authenticate
# when the saved session expires: it drives login.microsoftonline.com headlessly
# and pings you on Telegram to approve the Authenticator push (or enter the
# number-match code). If left blank, expiry falls back to the manual
# setup_session.py flow.
#
# SECURITY: MS_PASSWORD is your Microsoft account password. Restrict this file:
#   chmod 600 .env
MS_EMAIL=
MS_PASSWORD=

# How often the keep-alive probe visits HRMS to refresh cookies and detect
# expiry early. 6 hours is a good default; lower means faster recovery but
# more headless-browser launches.
KEEP_ALIVE_INTERVAL_HOURS=6
